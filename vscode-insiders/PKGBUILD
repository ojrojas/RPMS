# Maintainer: Oscar Rojas

pkgname=visual-studio-code-insiders-bin
pkgver=1.118.0
pkgrel=1
pkgdesc="Visual Studio Code - Insiders (Wayland support)"
arch=('x86_64')
url="https://code.visualstudio.com/"
license=('custom:Microsoft')
depends=('glibc' 'gtk3' 'nss' 'alsa-lib' 'libsecret' 'wayland' 'libxkbcommon' 'libdrm' 'libglvnd')
optdepends=('git: version control' 'gvfs: GNOME')
provides=('code-insiders')
conflicts=('code' 'vscodium-bin' 'code-oss' 'visual-studio-code-bin')
options=('!strip' '!debug')
source=("code-insiders.desktop")
sha256sums=('SKIP')

# return the full upstream version string (e.g. 1.110.0-insider)
get_fullver() {
  curl -s https://update.code.visualstudio.com/api/releases/insider | \
    grep -oE '"[0-9]+(\.[0-9]+)*-insider"' | head -n1 | tr -d '"'
}

# pkgver must not contain hyphens, so strip the "-insider" suffix here
pkgver() {
  get_fullver | sed 's/-insider$//'
}

prepare() {
  _full=$(get_fullver)
  echo "➡️ Download VS Code Insiders versión ${_full} ..."
  curl -L -o "vscode-linux-x64.tar.gz" \
    "https://update.code.visualstudio.com/${_full}/linux-x64/insider"

  echo "➡️ Calculate checksum..."
  sha256sum "vscode-linux-x64.tar.gz" | cut -d' ' -f1 > "vscode-linux-x64.tar.gz.sha256"
}

package() {
  install -d "$pkgdir/opt/visual-studio-code-insiders"
  tar -xzf vscode-linux-x64.tar.gz -C "$pkgdir/opt/visual-studio-code-insiders" --strip-components=1

  install -Dm644 "$pkgdir/opt/visual-studio-code-insiders/resources/app/resources/linux/code.png" \
    "$pkgdir/usr/share/pixmaps/code.png"

  install -Dm644 "$srcdir/code-insiders.desktop" "$pkgdir/usr/share/applications/code.desktop"
  sed -i 's|@@NAME@@|Visual Studio Code Insiders (Wayland)|g' "$pkgdir/usr/share/applications/code.desktop"
  sed -i 's|@@EXEC@@|/opt/visual-studio-code-insiders/code-insiders --enable-features=WaylandWindowDecorations --ozone-platform=wayland|g' \
    "$pkgdir/usr/share/applications/code.desktop"

install -Dm755 /dev/stdin "$pkgdir/usr/bin/code-insiders" <<'EOF'
#!/bin/sh
nohup /opt/visual-studio-code-insiders/code-insiders \
  --enable-features=WaylandWindowDecorations \
  --ozone-platform=wayland \
  "$@" >/dev/null 2>&1 &
disown
EOF



}
